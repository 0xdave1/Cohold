# =============================================================================
# FRONTEND ENVIRONMENT - Example (copy to .env.local or .env for Next.js)
# =============================================================================
# Only NEXT_PUBLIC_* variables are exposed to the browser. No secrets here.
# =============================================================================

# -----------------------------------------------------------------------------
# URLs (must match your deployment)
# -----------------------------------------------------------------------------
# Full URL where this Next.js app is served.
# Local: http://localhost:3000 | Production: https://cohold.co
NEXT_PUBLIC_APP_URL=https://cohold.co

# Canonical site URL for Open Graph / PWA metadata (HTTPS in production).
# Production canonical
NEXT_PUBLIC_SITE_URL=https://cohold.co

# Backend API base URL (no trailing slash). Must point to the running backend.
# Local: http://localhost:4000/api/v1 | Production: https://cohold.onrender.com/api/v1
NEXT_PUBLIC_API_URL=https://cohold.onrender.com/api/v1

# -----------------------------------------------------------------------------
# Feature flags (safe to toggle; no secrets)
# -----------------------------------------------------------------------------
# Enable peer-to-peer transfer UI and flows.
NEXT_PUBLIC_ENABLE_P2P_TRANSFERS=true
# Enable real-time features (e.g. WebSocket / live updates).
NEXT_PUBLIC_ENABLE_REAL_TIME=true
