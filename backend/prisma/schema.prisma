generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// End-user accounts hold liquid balances via Wallet[] (per currency).
/// Synthetic users (platform@internal, escrow-*) hold ESCROW / PLATFORM funds — never mix with real users in application logic.
model User {
  id                    String                @id @default(uuid())
  email                 String                @unique
  emailVerifiedAt       DateTime?
  firstName             String?
  lastName              String?
  phoneNumber           String?
  phoneCountryCode      String?
  nationality           String?
  houseNumber           String?
  streetName            String?
  city                  String?
  state                 String?
  bvn                   String?               @unique
  paystackCustomerCode  String?               @unique
  username              String?               @unique
  passwordHash          String
  kycStatus             KycStatus             @default(PENDING)
  onboardingCompletedAt DateTime?
  isFrozen              Boolean               @default(false)
  lastLoginAt           DateTime?
  profilePhotoKey       String?
  profileImageUrl       String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  investments           Investment[]
  investmentReturns     InvestmentReturn[]
  kycVerification       KycVerification?
  notifications         Notification[]
  transactions          Transaction[]         @relation("UserTransactions")
  virtualAccounts       VirtualAccount[]
  wallets               Wallet[]
  supportConversations  SupportConversation[]
  supportMessages       SupportMessage[]
  sentP2PTransfers      P2PTransfer[]         @relation("P2PSender")
  receivedP2PTransfers  P2PTransfer[]         @relation("P2PRecipient")
  linkedBankAccounts    LinkedBankAccount[]
  withdrawals           Withdrawal[]

  @@index([email])
  @@index([username])
}

model Admin {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String
  role                 AdminRole             @default(DATA_UPLOADER)
  fullName             String?
  phoneNumber          String?
  canSupport           Boolean               @default(false)
  accountStatus        AdminAccountStatus    @default(ACTIVE)
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  activities           AdminActivityLog[]
  distributions        Distribution[]
  kycReviews           KycVerification[]
  supportConversations SupportConversation[]
  supportMessages      SupportMessage[]
  supportPresence      SupportPresence?

  @@index([accountStatus])
  @@index([email])
  @@index([canSupport])
}

model SupportConversation {
  id              String          @id @default(uuid())
  referenceCode   String          @unique
  userId          String
  assignedAdminId String?
  category        SupportCategory
  status          SupportStatus   @default(OPEN)
  priority        SupportPriority @default(NORMAL)
  isDispute       Boolean         @default(false)
  subject         String?
  metadata        Json?
  lastMessageAt   DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user          User             @relation(fields: [userId], references: [id])
  assignedAdmin Admin?           @relation(fields: [assignedAdminId], references: [id])
  messages      SupportMessage[]

  @@index([userId, updatedAt])
  @@index([assignedAdminId, status])
  @@index([status, isDispute])
  @@index([category])
  @@index([lastMessageAt])
}

model SupportMessage {
  id             String             @id @default(uuid())
  conversationId String
  senderType     SupportSenderType
  senderUserId   String?
  senderAdminId  String?
  content        String
  messageType    SupportMessageType @default(TEXT)
  metadata       Json?
  readAt         DateTime?
  createdAt      DateTime           @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id])
  senderUser   User?               @relation(fields: [senderUserId], references: [id])
  senderAdmin  Admin?              @relation(fields: [senderAdminId], references: [id])
  attachments  SupportAttachment[]

  @@index([conversationId, createdAt])
  @@index([readAt])
  @@index([senderType])
}

model SupportAttachment {
  id         String   @id @default(uuid())
  messageId  String
  storageKey String
  mimeType   String
  sizeBytes  Int
  fileName   String?
  createdAt  DateTime @default(now())

  message SupportMessage @relation(fields: [messageId], references: [id])

  @@index([messageId])
  @@index([createdAt])
}

model SupportPresence {
  adminId    String   @unique
  isOnline   Boolean  @default(false)
  lastSeenAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([isOnline, updatedAt])
}

model Wallet {
  id            String        @id @default(uuid())
  userId        String
  currency      Currency
  balance       Decimal       @default(0) @db.Decimal(19, 4)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ledgerEntries Transaction[] @relation("WalletTransactions")
  user          User          @relation(fields: [userId], references: [id])
  withdrawals   Withdrawal[]

  @@unique([userId, currency])
  @@index([userId, currency])
}

model Transaction {
  id                String               @id @default(uuid())
  walletId          String?
  userId            String?
  reference         String               @unique
  externalReference String?
  type              TransactionType
  status            TransactionStatus
  amount            Decimal              @db.Decimal(19, 4)
  /// Fee portion (e.g. investment fee, profit-based sell fee, ROI platform cut). Nullable for legacy rows.
  fee               Decimal?             @db.Decimal(19, 4)
  /// Net principal / net to user depending on context (see metadata.ledgerRole when needed).
  netAmount         Decimal?             @db.Decimal(19, 4)
  currency          Currency
  direction         TransactionDirection
  metadata          Json?
  propertyId        String?
  investmentId      String?
  /// Groups all legs of one business operation (BUY/SELL/ROI/swap) for audit — equals primary tx reference where possible.
  groupId           String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  investment        Investment?          @relation("InvestmentLedgerTx", fields: [investmentId], references: [id])
  property          Property?            @relation("PropertyTransactions", fields: [propertyId], references: [id])
  user              User?                @relation("UserTransactions", fields: [userId], references: [id])
  wallet            Wallet?              @relation("WalletTransactions", fields: [walletId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([reference])
  @@index([groupId])
  @@index([externalReference])
  @@index([createdAt])
  @@index([type])
  @@index([propertyId])
  @@index([investmentId])
}

/// User-linked payout destination (NGN-only at product level; currency field kept for future).
model LinkedBankAccount {
  id                      String   @id @default(uuid())
  userId                  String
  currency                Currency
  accountNumber           String
  bankName                String
  accountName             String
  bankCode                String?
  isDefault               Boolean  @default(false)
  isVerified              Boolean  @default(false)
  providerRecipientCode   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals  Withdrawal[]

  @@unique([userId, currency, accountNumber])
  @@index([userId, createdAt])
}

/// Bank payout request: funds are debited from wallet when created; status tracks provider lifecycle.
model Withdrawal {
  id                    String            @id @default(uuid())
  userId                String
  idempotencyKey        String
  walletId              String
  linkedBankAccountId   String
  reference             String            @unique
  providerReference     String?
  providerTransferCode  String?
  amount                Decimal           @db.Decimal(19, 4)
  fee                   Decimal           @default(0) @db.Decimal(19, 4)
  netAmount             Decimal           @db.Decimal(19, 4)
  currency              Currency
  status                WithdrawalStatus  @default(PENDING)
  failureReason         String?
  initiatedAt           DateTime          @default(now())
  processedAt           DateTime?
  completedAt           DateTime?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet            Wallet            @relation(fields: [walletId], references: [id])
  linkedBankAccount LinkedBankAccount @relation(fields: [linkedBankAccountId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@unique([userId, idempotencyKey])
}

/// Explicit P2P transfer record (idempotency, receipts, history).
/// Ledger source of truth remains Transaction legs (DEBIT/CREDIT) grouped by `groupId`.
model P2PTransfer {
  id             String    @id @default(uuid())
  senderId       String
  recipientId    String
  currency       Currency
  amount         Decimal   @db.Decimal(19, 4)
  fee            Decimal   @default(0) @db.Decimal(19, 4)
  recipientAmount Decimal  @db.Decimal(19, 4)
  note           String?
  idempotencyKey String
  groupId        String    @unique
  createdAt      DateTime  @default(now())

  sender         User      @relation("P2PSender", fields: [senderId], references: [id])
  recipient      User      @relation("P2PRecipient", fields: [recipientId], references: [id])

  @@unique([senderId, idempotencyKey])
  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
}

model Property {
  id                String             @id @default(uuid())
  title             String
  description       String
  location          String
  status            PropertyStatus     @default(PUBLISHED)
  totalValue        Decimal            @db.Decimal(24, 8)
  sharePrice        Decimal            @db.Decimal(24, 8)
  currency          Currency
  minInvestment     Decimal            @db.Decimal(19, 4)
  currentRaised     Decimal            @default(0) @db.Decimal(24, 8)
  sharesTotal       Decimal            @db.Decimal(24, 8)
  sharesSold        Decimal            @default(0) @db.Decimal(24, 8)
  /// Annual yield as a unitless rate, e.g. 0.125 = 12.5% per year (used for scheduled ROI math).
  annualYield       Decimal?           @db.Decimal(12, 8)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  distributions     Distribution[]
  investments       Investment[]
  investmentReturns InvestmentReturn[]
  documents         PropertyDocument[]
  images            PropertyImage[]
  transactions      Transaction[]      @relation("PropertyTransactions")

  @@index([status, createdAt])
  @@index([deletedAt])
}

model PropertyDocument {
  id         String   @id @default(uuid())
  propertyId String
  type       String
  s3Key      String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  /// Legacy public URL field (do not use as source of truth). Kept for compatibility.
  url        String?
  /// Private storage key in R2/S3. Derive signed read URL at request time.
  storageKey String?
  altText    String?
  position   Int
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model Investment {
  id                 String               @id @default(uuid())
  userId             String
  propertyId         String
  /// Principal invested in this position (cost basis pool for sells).
  amount             Decimal              @db.Decimal(19, 4)
  currency           Currency
  shares             Decimal              @db.Decimal(24, 8)
  sharePrice         Decimal              @db.Decimal(24, 8)
  ownershipPercent   Decimal              @db.Decimal(10, 6)
  /// Cumulative net ROI credited to the user wallet from this position.
  totalReturns       Decimal              @default(0) @db.Decimal(19, 4)
  status             InvestmentStatus     @default(ACTIVE)
  clientReference    String?              @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  payouts            DistributionPayout[]
  property           Property             @relation(fields: [propertyId], references: [id])
  user               User                 @relation(fields: [userId], references: [id])
  investmentReturns  InvestmentReturn[]
  ledgerTransactions Transaction[]        @relation("InvestmentLedgerTx")

  @@index([userId])
  @@index([propertyId])
  @@index([userId, propertyId])
}

/// Scheduled ROI accrual per investment position — source of truth for yield paid (not frontend estimates).
model InvestmentReturn {
  id           String     @id @default(cuid())
  userId       String
  propertyId   String
  investmentId String
  amount       Decimal    @db.Decimal(19, 4)
  fee          Decimal    @db.Decimal(19, 4)
  netAmount    Decimal    @db.Decimal(19, 4)
  period       String
  status       String
  createdAt    DateTime   @default(now())
  investment   Investment @relation(fields: [investmentId], references: [id])
  property     Property   @relation(fields: [propertyId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([investmentId, period])
  @@index([userId])
  @@index([propertyId, period])
}

model KycVerification {
  id                 String    @id @default(uuid())
  userId             String    @unique
  status             KycStatus @default(PENDING)
  governmentIdType   String?
  governmentIdNumber String?
  /// Legacy single-key field (kept for backward compatibility). Prefer explicit keys below.
  documentKey        String?
  documentFrontKey   String?
  documentBackKey    String?
  selfieKey          String?
  failureReason      String?
  requiresReview     Boolean   @default(false)
  reviewedById       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  reviewedBy         Admin?    @relation(fields: [reviewedById], references: [id])
  user               User      @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
}

model VirtualAccount {
  id            String   @id @default(uuid())
  userId        String
  provider      String
  accountNumber String   @unique
  accountName   String
  bankName      String
  currency      Currency
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, currency])
}

model Distribution {
  id           String               @id @default(uuid())
  propertyId   String
  totalAmount  Decimal              @db.Decimal(19, 4)
  platformFee  Decimal              @default(0) @db.Decimal(19, 4)
  currency     Currency
  status       DistributionStatus   @default(PENDING)
  executedById String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  executedBy   Admin                @relation(fields: [executedById], references: [id])
  property     Property             @relation(fields: [propertyId], references: [id])
  payouts      DistributionPayout[]

  @@index([propertyId, status])
}

model DistributionPayout {
  id             String       @id @default(uuid())
  distributionId String
  investmentId   String
  amount         Decimal      @db.Decimal(19, 4)
  currency       Currency
  createdAt      DateTime     @default(now())
  distribution   Distribution @relation(fields: [distributionId], references: [id])
  investment     Investment   @relation(fields: [investmentId], references: [id])

  @@index([distributionId])
  @@index([investmentId])
}

model AdminActivityLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
}

model PaystackWebhookEvent {
  id          String    @id @default(uuid())
  event       String
  reference   String?
  payload     Json?
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([reference])
  @@index([event, createdAt])
}

/// In-app notifications for users (investment confirmations, wallet events, KYC updates, system messages).
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

enum AdminAccountStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum Currency {
  NGN
  USD
  GBP
  EUR
}

enum KycStatus {
  PENDING
  VERIFIED
  FAILED
  REQUIRES_REVIEW
}

enum AdminRole {
  DATA_UPLOADER
  APPROVER
  SUPER_ADMIN
  COMPLIANCE_ADMIN
}

enum SupportCategory {
  GENERAL_SUPPORT
  PAYMENT_ISSUE
  WITHDRAWAL_ISSUE
  INVESTMENT_ISSUE
  WALLET_ISSUE
  KYC_ISSUE
  PROPERTY_ISSUE
  DISPUTE
}

enum SupportStatus {
  OPEN
  WAITING_FOR_ADMIN
  WAITING_FOR_USER
  LIVE
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportSenderType {
  USER
  ADMIN
  BOT
  SYSTEM
}

enum SupportMessageType {
  TEXT
  INTERNAL_NOTE
  SYSTEM_EVENT
}

enum TransactionType {
  WALLET_TOP_UP
  WALLET_WITHDRAWAL
  WALLET_SWAP
  P2P_TRANSFER
  INVESTMENT
  BUY
  SELL
  ROI
  PROPERTY_FUNDING
  DISTRIBUTION
  FEE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DistributionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  INVESTMENT_SUCCESS
  INVESTMENT_SOLD
  WALLET_FUNDED
  WITHDRAWAL_INITIATED
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_FAILED
  KYC_APPROVED
  KYC_REJECTED
  KYC_REQUIRES_REVIEW
  PROPERTY_UPDATE
  ROI_CREDITED
  SYSTEM_MESSAGE
  WELCOME
}
