# =============================================================================
# BACKEND ENVIRONMENT - Example (copy to .env and fill in real values)
# =============================================================================
# In production: use real secrets; never commit .env to git.
# In development: placeholders below are valid for local runs (DB/Redis via Docker).
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# development | staging | production | test
NODE_ENV=development
# Port the API listens on (e.g. 4000 when frontend is on 3000)
PORT=4000
# URL path prefix for all API routes (must match frontend NEXT_PUBLIC_API_URL path)
API_PREFIX=/api/v1
# Primary frontend origin for cookie/CORS auth checks (production: https://cohold.vercel.app)
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated extra browser origins for CORS (credentials). Defaults already include
# http://localhost:3000, https://cohold.vercel.app, https://cohold.onrender.com
# CORS_ORIGIN=https://preview.vercel.app

# -----------------------------------------------------------------------------
# Database (REQUIRED for local run)
# -----------------------------------------------------------------------------
# Local PostgreSQL on Windows: use postgres user, create DB with: createdb cohold (or psql)
# Replace YOUR_PASSWORD with your Windows PostgreSQL postgres user password.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/cohold
# Redis optional (currently disabled – leave unset or comment out)
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT – Unified for users and admins (REQUIRED; strong secrets in production)
# -----------------------------------------------------------------------------
# Min 32 characters. Production: e.g. openssl rand -base64 48 (64+ chars recommended).
JWT_ACCESS_SECRET=dev-access-secret-min-32-chars-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-chars-change-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=cohold-api
JWT_AUDIENCE=cohold-client
# Optional extra pepper for hashing refresh sessions in DB
# AUTH_SESSION_PEPPER=replace-with-strong-secret
# Max absolute refresh-chain lifetime (days)
AUTH_MAX_SESSION_LIFETIME_DAYS=30

# -----------------------------------------------------------------------------
# Flutterwave (REQUIRED; single payment provider)
# -----------------------------------------------------------------------------
FLW_SECRET_KEY=your_secret_key
FLW_PUBLIC_KEY=your_public_key
FLW_WEBHOOK_SECRET=your_webhook_secret
FLW_BASE_URL=https://api.flutterwave.com/v3
# Optional aliases (equivalent to FLW_*):
# FLUTTERWAVE_SECRET_KEY=your_secret_key
# FLUTTERWAVE_PUBLIC_KEY=your_public_key
# FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret
# FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# S3 / Cloudflare R2 (REQUIRED; must match your bucket)
# -----------------------------------------------------------------------------
# R2: R2 → Manage R2 API Tokens. S3: IAM access key. Dev: placeholders work if storage is optional.
S3_ACCESS_KEY=your_access_key_id
S3_SECRET_KEY=your_secret_access_key
S3_BUCKET=cohold-documents
# R2: use "auto". AWS: e.g. us-east-1
S3_REGION=auto
# R2: https://<account_id>.r2.cloudflarestorage.com. AWS: leave empty or use regional endpoint.
S3_ENDPOINT=https://xxxxxxxxxxxx.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# Email (REQUIRED; e.g. SendGrid)
# -----------------------------------------------------------------------------
# SendGrid API key or other provider key. Production: use a real key; keep secret.
# Dev: placeholder disables sending (backend logs a warning but starts).
EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# Elasticsearch node URL for search. Omit or leave empty to disable search.
# ELASTICSEARCH_NODE=http://localhost:9200
# FX rates: optional API key for exchangerate-api.io paid tier.
# EXCHANGE_RATE_API_KEY=
